###

# get all logs for a tour

GET {{HostAddress}}/api/tours/{{TourId}}/logs
Authorization: Bearer {{Token}}

###

# search for logs by term

GET {{HostAddress}}/api/tours/{{TourId}}/logs/search?term=test
Authorization: Bearer {{Token}}

###

# create a new log for a tour

POST {{HostAddress}}/api/logs/
Authorization: Bearer {{Token}}
Content-Type: application/json

{
    "tourId": {{TourId}},
    "time": "2023-01-01T00:00:00Z",
    "comment": "This is a test log.",
    "difficulty": 3.1,
    "totalDistance": 100,
    "totalTime": "02:30:00",
    "rating": 4.7
}

###

# get a log by id

GET {{HostAddress}}/api/logs/{{LogId}}
Authorization: Bearer {{Token}}

###

# update a log

PUT {{HostAddress}}/api/logs/{{LogId}}
Authorization: Bearer {{Token}}
Content-Type: application/json

{
    "tourId": {{TourId}},
    "time": "2023-01-02T00:00:00Z",
    "comment": "This is an updated test log.",
    "difficulty": 4.2,
    "totalDistance": 120,
    "totalTime": "03:00:00",
    "rating": 4.9
}

###

# delete a log

DELETE {{HostAddress}}/api/logs/{{LogId}}
Authorization: Bearer {{Token}}

###